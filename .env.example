# URL of the Spring Boot backend used at build/runtime.
# Leave unset in local dev to use the same-origin "/api" proxy configured
# in vite.config.ts (which forwards to VITE_BACKEND_URL, default
# http://localhost:8080).
# VITE_API_BASE_URL=https://api.yourdomain.com

# Backend origin the Vite dev server proxies "/api" to. Only used by
# vite.config.ts during `npm run dev`.
VITE_BACKEND_URL=http://localhost:8082
